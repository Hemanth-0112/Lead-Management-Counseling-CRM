      "item": [
        {
          "name": "Create Counselor",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/counselors", "host": ["{{baseUrl}}"], "path": ["api", "counselors"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Priya Sharma\",\n  \"email\": \"priya.sharma@educrm.com\",\n  \"phone\": \"9876543210\",\n  \"department\": \"Engineering\"\n}"
            }
          }
        },
        {
          "name": "Get All Counselors",
